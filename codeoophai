import java.util.ArrayList;
import java.util.Scanner;

// Lớp đối tượng Bệnh nhân
class Patient {
    String id; 
    String name;
    String gender;
    String phone;
    String address;
    int age;

    public Patient(String id, String name, int age, String gender, String phone, String address) {
        this.id = id;
        this.name = name;
        this.age = age;
        this.gender = gender;
        this.phone = phone;
        this.address = address;
    }

    @Override
    public String toString() {
        return String.format("ID: %s | Tên: %s | Tuổi: %d | GT: %s | SĐT: %s | Đ/C: %s", 
                id, name, age, gender, phone, address);
    }
}

// Lớp đối tượng Admin
class Admin {
    String username, password;

    public Admin(String username, String password) {
        this.username = username;
        this.password = password;
    }
}
public class HospitalManagement {
    static ArrayList<Admin> adminList = new ArrayList<>();
    static ArrayList<Patient> patientList = new ArrayList<>();
    static Scanner sc = new Scanner(System.in);
    static Admin currentAdmin = null;

    public static void main(String[] args) {
        // Khởi tạo admin mặc định
        adminList.add(new Admin("admin", "123"));
        
        while (true) {
            if (currentAdmin == null) {
                login();
            } else {
                showMenu();
            }
        }
    }

    // 1. Xác thực đăng nhập
    setatic void login() {
        System.out.println("\n--- ĐĂNG NHẬP HỆ THỐNG ---");
        System.out.print("Username: ");
        String user = sc.nextLine();
        System.out.print("Password: ");
        String pass = sc.nextLine();

        for (Admin a : adminList) {
            if (a.username.equals(user) && a.password.equals(pass)) {
                currentAdmin = a;
                System.out.println(">> Đăng nhập thành công!");
                return;
            }
        }
        System.out.println("!! Sai tài khoản hoặc mật khẩu.");
    }

    static void showMenu() {
        System.out.println("\n--- MENU QUẢN LÝ ---");
        System.out.println("1. Quản lý Admin (Thêm/Sửa/Xóa)");
        System.out.println("2. Quản lý Bệnh nhân (Thêm/Sửa/Xóa/Xem)");
        System.out.println("3. Đăng xuất");
        System.out.print("Chọn: ");
        int choice = Integer.parseInt(sc.nextLine());

        switch (choice) {
            case 1 -> manageAdmins();
            case 2 -> managePatients();
            case 3 -> currentAdmin = null;
            default -> System.out.println("Chọn sai!");
        }
    }

    // 2. Quản lý tài khoản Admin
    static void manageAdmins() {
        System.out.println("1. Thêm Admin | 2. Sửa Admin | 3. Xóa Admin | 4. Quay lại");
        int sub = Integer.parseInt(sc.nextLine());
        if (sub == 1) {
            System.out.print("User mới: "); String u = sc.nextLine();
            System.out.print("Pass mới: "); String p = sc.nextLine();
            adminList.add(new Admin(u, p));
            System.out.println("Đã thêm.");
        } else if (sub == 3) {
            System.out.print("Nhập username cần xóa: "); String u = sc.nextLine();
            adminList.removeIf(a -> a.username.equals(u));
            System.out.println("Đã xử lý.");
        }
    }

    // 3. Quản lý bệnh nhân
    static void managePatients() {
        System.out.println("1. Thêm BN | 2. Xem DS | 3. Sửa BN | 4. Xóa BN");
        int sub = Integer.parseInt(sc.nextLine());
        
        switch (sub) {
            case 1 -> {
                System.out.print("Mã BN: "); String id = sc.nextLine();
                System.out.print("Tên: "); String name = sc.nextLine();
                System.out.print("Tuổi: "); int age = Integer.parseInt(sc.nextLine());
                System.out.print("SĐT: "); String phone = sc.nextLine();
                patientList.add(new Patient(id, name, age, "Nam", phone, "Hà Nội"));
                System.out.println("Đã thêm bệnh nhân.");
            }
            case 2 -> {
                System.out.println("--- DANH SÁCH BỆNH NHÂN ---");
                patientList.forEach(System.out::println);
            }
            case 4 -> {
                System.out.print("Nhập mã BN cần xóa: "); String id = sc.nextLine();
                patientList.removeIf(p -> p.id.equals(id));
                System.out.println("Đã xóa.");
            }
        }
    }
}
